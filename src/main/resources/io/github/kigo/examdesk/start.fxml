<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="io.github.kigo.examdesk.StartController" spacing="12" alignment="CENTER">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox spacing="8" alignment="CENTER">
        <Label text="問題数" />
        <TextField fx:id="countField" promptText="例: 10" prefWidth="120"/>
        <Button text="開始" onAction="#onStart"/>
    </HBox>

    <Label fx:id="messageLabel" text="" />

    <HBox spacing="8" alignment="CENTER">
        <Button fx:id="listResultsButton" text="結果一覧" onAction="#onListResults"/>
        <Button fx:id="resumeButton" text="試験再開" onAction="#onResumeExam"/>
    </HBox>

    <HBox spacing="8" alignment="CENTER_RIGHT" prefWidth="400">
        <Button fx:id="settingsButton" text="設定" onAction="#onOpenSettings"/>
    </HBox>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="io.github.kigo.examdesk.SettingsController" spacing="12" alignment="TOP_LEFT">
    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>

    <Label text="設定" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

    <HBox spacing="8" alignment="CENTER_LEFT">
        <Button fx:id="chooseDefaultPathButton" text="デフォルトパスを選択する" onAction="#onChooseDefaultPath"/>
        <Label fx:id="currentPathLabel" text="(未設定)" />
    </HBox>

    <CheckBox fx:id="autoOpenCheckBox" text="xmlを開く・保存する時にデフォルトパスを自動的に開く。" />

    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button text="保存" onAction="#onSave"/>
        <Button text="キャンセル" onAction="#onCancel"/>
    </HBox>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="io.github.kigo.examdesk.QuizController">
    <top>
        <HBox spacing="8" alignment="CENTER_LEFT">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Button fx:id="backButton" text="戻る" onAction="#onBack"/>
            <Button fx:id="tempSaveButton" text="一時保存" onAction="#onTempSave"/>
            <Label fx:id="infoLabel" text="" />
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <content>
                <VBox fx:id="questionsContainer" spacing="8">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <VBox spacing="8">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button fx:id="finishAnswersButton" text="解答終了" disable="true" onAction="#onFinishAnswers"/>
                <Button fx:id="gradeButton" text="採点" disable="true" onAction="#onGrade"/>
            </HBox>

            <Label fx:id="scoreLabel" text="" />

            <HBox alignment="CENTER_RIGHT">
                <Button fx:id="saveButton" text="結果保存" visible="false" onAction="#onSaveResults"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>